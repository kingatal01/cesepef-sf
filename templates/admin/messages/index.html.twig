{% extends 'admin/base.html.twig' %}
{% block admin_title %}Messages{% endblock %}

{% block admin_body %}
    <div class="mb-6 flex items-center justify-between">
        <p class="text-sm text-gray-500 dark:text-gray-400">
            <span class="font-medium text-gray-700 dark:text-gray-200">{{ messages|length }}</span> message(s) ·
            <span class="font-medium text-red-500">{{ messages|filter(m => not m.isRead)|length }} non lu(s)</span>
        </p>
        {% if messages is not empty %}
            <form method="post" action="{{ path('admin_messages_read_all') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('messages') }}">
                <button type="submit" class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:border-primary hover:text-primary dark:border-gray-600 dark:text-gray-300">Tout marquer comme lu</button>
            </form>
        {% endif %}
    </div>

    {% if messages is empty %}
        <div class="rounded-xl bg-white py-16 text-center shadow-sm dark:bg-gray-900">
            <p class="text-sm text-gray-400">Aucun message pour l'instant</p>
            <p class="mt-1 text-xs text-gray-400">Les messages envoyés depuis la page Contact apparaîtront ici.</p>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for m in messages %}
                <div class="rounded-xl border bg-white p-5 shadow-sm dark:bg-gray-900 {{ m.isRead ? 'border-gray-100 dark:border-gray-700' : 'border-primary/30 ring-1 ring-primary/10' }}">
                    <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0 flex-1">
                            <div class="mb-1 flex flex-wrap items-center gap-2">
                                {% if not m.isRead %}<span class="h-2 w-2 shrink-0 rounded-full bg-primary"></span>{% endif %}
                                <p class="font-semibold text-gray-800 dark:text-white">{{ m.name }}</p>
                                <a href="mailto:{{ m.email }}" class="text-xs text-primary hover:underline">{{ m.email }}</a>
                                {% if m.phone %}<span class="text-xs text-gray-400">· {{ m.phone }}</span>{% endif %}
                            </div>
                            {% if m.subject %}<p class="text-sm font-medium text-gray-700 dark:text-gray-200">{{ m.subject }}{% if m.service %} — {{ m.service }}{% endif %}</p>{% endif %}
                            <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">{{ m.message }}</p>
                            <p class="mt-2 text-xs text-gray-400">{{ m.createdAt|date('d/m/Y H:i') }}</p>
                        </div>
                        <div class="flex shrink-0 items-center gap-1">
                            <form method="post" action="{{ path('admin_messages_star', {id: m.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('messages') }}">
                                <button type="submit" title="Favori" class="rounded-lg p-2 {{ m.isStarred ? 'text-yellow-500' : 'text-gray-300 hover:text-yellow-500' }}">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_messages_read', {id: m.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('messages') }}">
                                <button type="submit" class="rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 hover:border-primary hover:text-primary dark:border-gray-600 dark:text-gray-300">{{ m.isRead ? 'Marquer non lu' : 'Marquer lu' }}</button>
                            </form>
                            <form method="post" action="{{ path('admin_messages_delete', {id: m.id}) }}" data-turbo-confirm="Supprimer ce message ?">
                                <input type="hidden" name="_token" value="{{ csrf_token('messages') }}">
                                <button type="submit" class="rounded-lg border border-red-100 px-3 py-1.5 text-xs font-medium text-red-500 hover:bg-red-50">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
