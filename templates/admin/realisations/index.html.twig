{% extends 'admin/base.html.twig' %}
{% block admin_title %}Réalisations{% endblock %}

{% block admin_body %}
    <div class="mb-6 flex items-center justify-between">
        <p class="text-sm text-gray-500 dark:text-gray-400"><span class="font-medium text-gray-700 dark:text-gray-200">{{ realisations|length }}</span> réalisation(s)</p>
        <button data-action="modal#open" data-modal-id-param="modal-real" class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90">
            {{ ux_icon('lucide:plus', { class: 'h-4 w-4' }) }}
            Ajouter une réalisation
        </button>
    </div>

    <div class="rounded-xl bg-white shadow-sm dark:bg-gray-900">
        {% if realisations is empty %}
            <div class="flex flex-col items-center justify-center gap-3 py-16 text-gray-400">
                <p class="text-sm">Aucune réalisation pour l'instant</p>
                <button data-action="modal#open" data-modal-id-param="modal-real" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white">Ajouter la première réalisation</button>
            </div>
        {% else %}
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="border-b border-gray-100 dark:border-gray-700">
                        <th class="px-6 py-4 font-semibold text-gray-500 dark:text-gray-400">Titre</th>
                        <th class="hidden px-6 py-4 font-semibold text-gray-500 dark:text-gray-400 md:table-cell">Secteur</th>
                        <th class="hidden px-6 py-4 font-semibold text-gray-500 dark:text-gray-400 lg:table-cell">Pays / Année</th>
                        <th class="px-6 py-4 font-semibold text-gray-500 dark:text-gray-400">Statut</th>
                        <th class="px-6 py-4 font-semibold text-gray-500 dark:text-gray-400">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in realisations %}
                        <tr class="border-b border-gray-50 transition hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-gray-800">
                            <td class="px-6 py-4">
                                <p class="font-medium text-gray-800 dark:text-white">{{ r.title }}</p>
                                {% if r.client %}<p class="text-xs text-gray-400">{{ r.client }}</p>{% endif %}
                            </td>
                            <td class="hidden px-6 py-4 text-gray-600 dark:text-gray-300 md:table-cell">{{ r.sector ?: '—' }}</td>
                            <td class="hidden px-6 py-4 text-gray-600 dark:text-gray-300 lg:table-cell">{{ r.country }}{% if r.year %} · {{ r.year }}{% endif %}</td>
                            <td class="px-6 py-4">
                                <form method="post" action="{{ path('admin_realisations_toggle', {id: r.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('realisations') }}">
                                    <button type="submit" class="inline-flex rounded-full px-3 py-1 text-xs font-medium transition {{ r.isPublished ? 'bg-green-100 text-green-700 hover:bg-green-200' : 'bg-gray-100 text-gray-500 hover:bg-gray-200' }}">{{ r.isPublished ? 'Visible' : 'Masqué' }}</button>
                                </form>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex gap-2">
                                    <a href="{{ path('admin_realisations_edit', {id: r.id}) }}" class="rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 hover:border-primary hover:text-primary dark:border-gray-600 dark:text-gray-300">Modifier</a>
                                    <form method="post" action="{{ path('admin_realisations_delete', {id: r.id}) }}" data-turbo-confirm="Supprimer « {{ r.title }} » ?">
                                        <input type="hidden" name="_token" value="{{ csrf_token('realisations') }}">
                                        <button type="submit" class="rounded-lg border border-red-100 px-3 py-1.5 text-xs font-medium text-red-500 hover:bg-red-50">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    <div id="modal-real" data-modal-target="overlay" data-action="modal#backdrop" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4 flex">
        <div class="flex max-h-[90vh] w-full max-w-2xl flex-col rounded-2xl bg-white shadow-2xl dark:bg-gray-900">
            <div class="flex shrink-0 items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-700">
                <h2 class="text-base font-semibold text-gray-800 dark:text-white">Ajouter une réalisation</h2>
                <button data-action="modal#close" class="rounded-lg p-1 text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800">{{ ux_icon('lucide:x', { class: 'h-[18px] w-[18px]' }) }}</button>
            </div>
            {{ include('admin/realisations/_form.html.twig', { action: path('admin_realisations_new'), realisation: null, cancel_modal: true }) }}
        </div>
    </div>
{% endblock %}
