{% extends 'admin/base.html.twig' %}
{% block admin_title %}Modifier une offre{% endblock %}

{% block admin_body %}
    <div class="mb-6">
        <a href="{{ path('admin_services') }}" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary">
            {{ ux_icon('lucide:chevron-left', { class: 'h-4 w-4' }) }}
            Retour à la liste
        </a>
    </div>
    <div class="max-w-lg rounded-2xl bg-white shadow-sm dark:bg-gray-900">
        <div class="border-b border-gray-100 px-6 py-4 dark:border-gray-700">
            <h2 class="text-base font-semibold text-gray-800 dark:text-white">{{ service.title }}</h2>
        </div>
        {{ include('admin/services/_form.html.twig', { action: path('admin_services_edit', {id: service.id}), service: service, cancel_modal: false }) }}
    </div>
{% endblock %}
