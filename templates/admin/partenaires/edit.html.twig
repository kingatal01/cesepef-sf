{% extends 'admin/base.html.twig' %}
{% block admin_title %}Modifier un partenaire{% endblock %}

{% block admin_body %}
    <div class="mb-6">
        <a href="{{ path('admin_partenaires') }}" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            Retour à la liste
        </a>
    </div>
    <div class="max-w-lg rounded-2xl bg-white shadow-sm dark:bg-gray-900">
        <div class="border-b border-gray-100 px-6 py-4 dark:border-gray-700">
            <h2 class="text-base font-semibold text-gray-800 dark:text-white">{{ partner.name }}</h2>
        </div>
        {{ include('admin/partenaires/_form.html.twig', { action: path('admin_partenaires_edit', {id: partner.id}), partner: partner, cancel_modal: false }) }}
    </div>
{% endblock %}
