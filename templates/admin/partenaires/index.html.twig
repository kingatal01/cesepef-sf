{% extends 'admin/base.html.twig' %}
{% block admin_title %}Partenaires{% endblock %}

{% block admin_body %}
    <div class="mb-6 flex items-center justify-between">
        <p class="text-sm text-gray-500 dark:text-gray-400"><span class="font-medium text-gray-700 dark:text-gray-200">{{ partners|length }}</span> partenaires</p>
        <button data-action="modal#open" data-modal-id-param="modal-partner" class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90">
            {{ ux_icon('lucide:plus', { class: 'h-4 w-4' }) }}
            Ajouter un partenaire
        </button>
    </div>

    {% if partners is empty %}
        <div class="rounded-xl bg-white py-16 text-center shadow-sm dark:bg-gray-900">
            <p class="mb-3 text-sm text-gray-400">Aucun partenaire pour l'instant</p>
            <button data-action="modal#open" data-modal-id-param="modal-partner" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white">Ajouter le premier partenaire</button>
        </div>
    {% else %}
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
            {% for p in partners %}
                <div class="rounded-xl border border-gray-100 bg-white p-5 text-center shadow-sm dark:border-gray-700 dark:bg-gray-900">
                    <div class="mx-auto mb-3 flex h-16 w-full items-center justify-center overflow-hidden rounded-lg bg-gray-50 px-2 dark:bg-gray-800">
                        {% if p.logo %}<img src="{{ p.logo }}" alt="{{ p.name }}" class="max-h-12 w-auto object-contain">
                        {% else %}<span class="text-xs font-semibold text-gray-400">{{ p.name }}</span>{% endif %}
                    </div>
                    <p class="truncate text-sm font-medium text-gray-800 dark:text-white">{{ p.name }}</p>
                    <span class="mt-1 inline-block rounded-full px-2 py-0.5 text-[10px] font-medium {{ p.isActive ? 'bg-primary/10 text-primary' : 'bg-gray-100 text-gray-400' }}">{{ p.category ?: 'Sans catégorie' }}</span>
                    <div class="mt-3 flex justify-center gap-2">
                        <a href="{{ path('admin_partenaires_edit', {id: p.id}) }}" class="rounded-lg border border-gray-200 px-3 py-1 text-xs font-medium text-gray-600 hover:border-primary hover:text-primary dark:border-gray-600 dark:text-gray-300">Modifier</a>
                        <form method="post" action="{{ path('admin_partenaires_delete', {id: p.id}) }}" data-turbo-confirm="Supprimer « {{ p.name }} » ?">
                            <input type="hidden" name="_token" value="{{ csrf_token('partenaires') }}">
                            <button type="submit" class="rounded-lg border border-red-100 px-3 py-1 text-xs font-medium text-red-500 hover:bg-red-50">Suppr.</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div id="modal-partner" data-modal-target="overlay" data-action="modal#backdrop" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4 flex">
        <div class="flex w-full max-w-lg flex-col rounded-2xl bg-white shadow-2xl dark:bg-gray-900">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-700">
                <h2 class="text-base font-semibold text-gray-800 dark:text-white">Ajouter un partenaire</h2>
                <button data-action="modal#close" class="rounded-lg p-1 text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800">{{ ux_icon('lucide:x', { class: 'h-[18px] w-[18px]' }) }}</button>
            </div>
            {{ include('admin/partenaires/_form.html.twig', { action: path('admin_partenaires_new'), partner: null, cancel_modal: true }) }}
        </div>
    </div>
{% endblock %}
