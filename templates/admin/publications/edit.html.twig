{% extends 'admin/base.html.twig' %}
{% block admin_title %}Modifier une publication{% endblock %}

{% block admin_body %}
    <div class="mb-6">
        <a href="{{ path('admin_publications') }}" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary">
            {{ ux_icon('lucide:chevron-left', { class: 'h-4 w-4' }) }}
            Retour à la liste
        </a>
    </div>
    <div class="max-w-3xl rounded-2xl bg-white shadow-sm dark:bg-gray-900">
        <div class="border-b border-gray-100 px-6 py-4 dark:border-gray-700">
            <h2 class="text-base font-semibold text-gray-800 dark:text-white">{{ publication.title }}</h2>
            <p class="text-xs text-gray-400">/blog/{{ publication.slug }}</p>
        </div>
        {{ include('admin/publications/_form.html.twig', { action: path('admin_publications_edit', {id: publication.id}), publication: publication, cancel_modal: false }) }}
    </div>
{% endblock %}
