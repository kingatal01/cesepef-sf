{% extends 'base.html.twig' %}
{% set title = "À propos | CESEPEF, Cabinet d'Expertise Tchad" %}

{% block body %}
    {# ── Breadcrumb ── #}
    <section class="relative z-10 overflow-hidden pt-28 lg:pt-[150px]">
        <div class="container">
            <div class="-mx-4 flex flex-wrap items-center">
                <div class="w-full px-4 md:w-8/12 lg:w-7/12">
                    <div class="mb-8 max-w-[570px] md:mb-0 lg:mb-12">
                        <h1 class="mb-5 text-2xl font-bold text-black dark:text-white sm:text-3xl">À propos de CESEPEF</h1>
                        <p class="text-base font-medium leading-relaxed text-body-color">CESEPEF (Cabinet d'Expertise de Suivi &amp; Évaluation de Projets, d'Études et de Formations), est un bureau d'études et de conseil tchadien fondé en octobre 2021, réunissant des experts seniors pluridisciplinaires.</p>
                    </div>
                </div>
                <div class="w-full px-4 md:w-4/12 lg:w-5/12">
                    <div class="text-end">
                        <ul class="flex items-center md:justify-end">
                            <li class="flex items-center"><a href="{{ path('home') }}" class="pr-1 text-base font-medium text-body-color hover:text-primary">Accueil</a><span class="mr-3 block h-2 w-2 rotate-45 border-t-2 border-r-2 border-body-color"></span></li>
                            <li class="text-base font-medium text-primary">À propos</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="border-b border-body-color/[.15] pb-10 dark:border-white/[.15]"></div>
    </section>

    {# ── About Section One ── #}
    <section id="about" class="pt-16 md:pt-20 lg:pt-28">
        <div class="container">
            <div class="border-b border-body-color/[.15] pb-16 dark:border-white/[.15] md:pb-20 lg:pb-28">
                <div class="-mx-4 flex flex-wrap items-center">
                    <div class="w-full px-4 lg:w-1/2">
                        <div class="w-full" style="max-width: 570px; margin-bottom: 44px;">
                            <h2 class="mb-4 text-3xl font-bold !leading-tight text-black dark:text-white sm:text-4xl md:text-[45px]">Cabinet d'expertise indépendant basé à N'Djamena</h2>
                            <p class="text-base !leading-relaxed text-body-color md:text-lg">CESEPEF, Cabinet d'Expertise de Suivi &amp; Évaluation de Projets, d'Études et de Formations, est un bureau d'études et de conseil de droit tchadien, fondé en octobre 2021. Notre raison d'être : combler le déficit d'expertise indépendante, rigoureuse et contextualisée en matière de suivi-évaluation, d'études et de renforcement des capacités.</p>
                        </div>
                        <div class="mb-12 max-w-[570px] lg:mb-0">
                            <div class="mx-[-12px] flex flex-wrap">
                                {% for col in [
                                    ['Expertise nationale reconnue', 'Standards OCDE-CAD & GAR', "Indépendance d'analyse"],
                                    ["8+ pays d'intervention", 'Approche numérique & data', 'Livrables actionnables']
                                ] %}
                                    <div class="w-full px-3 sm:w-1/2 lg:w-full xl:w-1/2">
                                        {% for text in col %}
                                            <p class="text-body-color mb-5 flex items-center text-lg font-medium">
                                                <span class="bg-primary/10 text-primary mr-4 flex h-[30px] w-[30px] items-center justify-center rounded-md">
                                                    <svg width="16" height="13" viewBox="0 0 16 13" class="fill-current"><path d="M5.8535 12.6631C5.65824 12.8584 5.34166 12.8584 5.1464 12.6631L0.678505 8.1952C0.483242 7.99994 0.483242 7.68336 0.678505 7.4881L2.32921 5.83739C2.52467 5.64193 2.84166 5.64216 3.03684 5.83791L5.14622 7.95354C5.34147 8.14936 5.65859 8.14952 5.85403 7.95388L13.3797 0.420561C13.575 0.22513 13.8917 0.225051 14.087 0.420383L15.7381 2.07143C15.9333 2.26669 15.9333 2.58327 15.7381 2.77854L5.8535 12.6631Z"/></svg>
                                                </span>{{ text }}
                                            </p>
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                    <div class="w-full px-4 lg:w-1/2">
                        <div class="rounded-xs bg-primary/5 p-10 dark:bg-white/5">
                            <h3 class="mb-6 text-2xl font-bold text-black dark:text-white">Notre positionnement</h3>
                            <div class="mb-6">
                                <h4 class="mb-2 text-lg font-semibold text-primary">Ancrage national/Tchad</h4>
                                <p class="text-base text-body-color dark:text-body-color-dark">Connaissance fine du contexte politique, administratif et socio-économique tchadien, indispensable pour des analyses pertinentes et des recommandations applicables.</p>
                            </div>
                            <div class="mb-6">
                                <h4 class="mb-2 text-lg font-semibold text-primary">Couverture régionale Afrique centrale &amp; Sahel</h4>
                                <p class="text-base text-body-color dark:text-body-color-dark">Interventions démontrées au Mali, Niger, Burkina Faso, Sénégal, Côte d'Ivoire, Cameroun, RCA, à travers un réseau d'experts associés.</p>
                            </div>
                            <div>
                                <h4 class="mb-2 text-lg font-semibold text-primary">Standards internationaux</h4>
                                <p class="text-base text-body-color dark:text-body-color-dark">Alignement systématique sur les méthodologies OCDE-CAD, gestion axée sur les résultats (GAR), cadres logiques et théories du changement.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── About Section Two ── #}
    <section class="py-16 md:py-20 lg:py-28">
        <div class="container">
            <div class="-mx-4 flex flex-wrap items-center">
                <div class="w-full px-4 lg:w-1/2">
                    <div class="max-w-[470px]">
                        <div class="mb-9">
                            <h3 class="mb-4 text-xl font-bold text-black dark:text-white sm:text-2xl lg:text-xl xl:text-2xl">Notre vision</h3>
                            <p class="text-base font-medium leading-relaxed text-body-color sm:text-lg sm:leading-relaxed">Devenir le cabinet d'expertise de référence en Afrique centrale et au Sahel pour le suivi-évaluation, les études stratégiques et le renforcement des capacités, reconnu pour la rigueur de ses méthodes, l'indépendance de ses analyses et la valeur qu'il crée pour les décideurs et les populations.</p>
                        </div>
                        <div class="mb-9">
                            <h3 class="mb-4 text-xl font-bold text-black dark:text-white sm:text-2xl lg:text-xl xl:text-2xl">Notre mission</h3>
                            <p class="text-base font-medium leading-relaxed text-body-color sm:text-lg sm:leading-relaxed">Accompagner les gouvernements, les bailleurs internationaux, les agences onusiennes, les ONG et les acteurs privés dans la conception, le pilotage et l'évaluation de projets à fort impact. Notre mission ultime : transformer la donnée en décision, et la décision en impact mesurable pour les populations.</p>
                        </div>
                        <div class="mb-1">
                            <h3 class="mb-4 text-xl font-bold text-black dark:text-white sm:text-2xl lg:text-xl xl:text-2xl">Nos secteurs d'intervention</h3>
                            <p class="text-base font-medium leading-relaxed text-body-color sm:text-lg sm:leading-relaxed">Santé, éducation, agriculture, sécurité alimentaire, environnement, emploi &amp; formation professionnelle, gouvernance, action humanitaire.</p>
                        </div>
                    </div>
                </div>
                <div class="w-full px-4 lg:w-1/2">
                    <div class="rounded-xs bg-primary/5 p-10 dark:bg-white/5">
                        <h3 class="mb-6 text-2xl font-bold text-black dark:text-white">Nos valeurs fondatrices</h3>
                        {% for val in [
                            { title: 'Rigueur méthodologique', desc: 'Standards OCDE-CAD, GAR, ISO 20252, protocoles transparents et reproductibles.' },
                            { title: 'Indépendance', desc: 'Évaluations conduites en toute indépendance vis-à-vis des opérateurs des projets.' },
                            { title: 'Intégrité & éthique', desc: 'Confidentialité, protection des données, consentement éclairé principes non négociables.' },
                            { title: 'Excellence du livrable', desc: 'Chaque rapport soumis à un contrôle qualité interne avant remise au client.' },
                            { title: 'Ancrage local & terrain', desc: "Maîtrise des langues, codes culturels et réalités opérationnelles des zones d'intervention." },
                            { title: 'Innovation & numérique', desc: 'KoboToolbox, ODK, R, Stata, SPSS, Power BI, des données plus rapides, fiables et utiles.' }
                        ] %}
                            <div class="mb-4 flex items-start">
                                <span class="bg-primary/10 text-primary mr-3 mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-xs font-bold">{{ loop.index }}</span>
                                <div>
                                    <span class="font-semibold text-black dark:text-white">{{ val.title }} : </span>
                                    <span class="text-body-color dark:text-body-color-dark">{{ val.desc }}</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── Notre organisation & équipe ── #}
    <section class="py-16 md:py-20 lg:py-28">
        <div class="container">
            <div class="mb-16 text-center">
                <h2 class="mb-4 text-3xl font-bold text-black dark:text-white sm:text-4xl">Notre organisation &amp; équipe</h2>
                <p class="mx-auto max-w-[600px] text-base text-body-color dark:text-body-color-dark">CESEPEF s'appuie sur une organisation matricielle légère combinant un noyau permanent d'experts seniors et un réseau étendu de consultants associés.</p>
            </div>

            {# Gouvernance #}
            {% if gouvernance is not empty %}
                <div class="mb-12">
                    <h3 class="mb-6 text-2xl font-bold text-black dark:text-white">Gouvernance</h3>
                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
                        {% for m in gouvernance %}
                            <div class="rounded-xs bg-white p-6 shadow-two dark:bg-gray-dark">
                                <div class="mb-4 h-16 w-16 overflow-hidden rounded-full ring-2 ring-primary/20">
                                    {% if m.photo %}<img src="{{ m.photo }}" alt="{{ m.name }}" class="h-full w-full object-cover">
                                    {% else %}<div class="flex h-full w-full items-center justify-center bg-primary/10 text-2xl font-bold text-primary">{{ m.name|first }}</div>{% endif %}
                                </div>
                                <h4 class="mb-1 text-base font-bold text-black dark:text-white">{{ m.name }}</h4>
                                <p class="mb-2 text-sm font-semibold text-primary">{{ m.role }}</p>
                                {% if m.bio %}<p class="text-sm text-body-color dark:text-body-color-dark">{{ m.bio }}</p>{% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Départements opérationnels #}
            {% if chefs is not empty %}
                <div class="mb-12">
                    <h3 class="mb-6 text-2xl font-bold text-black dark:text-white">Départements opérationnels</h3>
                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                        {% for m in chefs %}
                            <div class="flex items-start gap-4 rounded-xs border border-body-color/10 p-6 dark:border-white/10">
                                <div class="flex aspect-square h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-full ring-2 ring-primary/20">
                                    {% if m.photo %}<img src="{{ m.photo }}" alt="{{ m.name }}" class="h-full w-full object-cover">
                                    {% else %}<div class="flex h-full w-full items-center justify-center bg-primary/10 text-base font-bold text-primary">{{ m.name|first }}</div>{% endif %}
                                </div>
                                <div>
                                    <h4 class="mb-0.5 text-lg font-bold text-black dark:text-white">{{ m.department }}</h4>
                                    <p class="mb-2 text-sm font-semibold text-primary">Chef de département : {{ m.name }}</p>
                                    {% if m.bio %}<p class="text-sm text-body-color dark:text-body-color-dark">{{ m.bio }}</p>{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Identité juridique #}
            <div class="rounded-xs bg-gray-light p-8 dark:bg-gray-dark">
                <h3 class="mb-6 text-2xl font-bold text-black dark:text-white">Identité juridique &amp; administrative</h3>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    {% for item in [
                        { label: 'Dénomination', value: 'CESEPEF Sarl' },
                        { label: 'Statut juridique', value: 'SARL pluripersonnelle' },
                        { label: 'Date de création', value: '20 octobre 2021' },
                        { label: 'NIF', value: '9031479' },
                        { label: 'Capital social', value: '1 000 000 FCFA' },
                        { label: 'Compte (NCB)', value: '32100050255 / ECOBANK' },
                        { label: 'Siège social', value: "N'Djamena, 7ᵉ Arrondissement" },
                        { label: 'Adresse postale', value: 'BP 716, N\'Djamena – Tchad' },
                        { label: 'Site internet', value: 'www.cesepef.org' }
                    ] %}
                        <div class="flex flex-col">
                            <span class="text-xs font-semibold uppercase tracking-wider text-body-color dark:text-body-color-dark">{{ item.label }}</span>
                            <span class="text-sm font-medium text-black dark:text-white">{{ item.value }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
