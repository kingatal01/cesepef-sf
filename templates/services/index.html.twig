{% extends 'base.html.twig' %}
{% set title = "Services — CESEPEF" %}

{% block body %}
<section class="relative z-10 overflow-hidden pt-28 lg:pt-[150px]">
    <div class="container">
        <div class="-mx-4 flex flex-wrap items-center">
            <div class="w-full px-4 md:w-8/12 lg:w-7/12">
                <div class="mb-8 max-w-[570px] md:mb-0 lg:mb-12">
                    <h1 class="mb-5 text-2xl font-bold text-black dark:text-white sm:text-3xl">Nos Services</h1>
                    <p class="text-base font-medium leading-relaxed text-body-color">Des offres modulaires et
                        adaptables, conçues pour répondre précisément aux besoins de nos clients. Chaque offre est
                        livrée avec un cahier des charges clair, un calendrier précis et des indicateurs de performance
                        contractuels.</p>
                </div>
            </div>
            <div class="w-full px-4 md:w-4/12 lg:w-5/12">
                <div class="text-end">
                    <ul class="flex items-center md:justify-end">
                        <li class="flex items-center"><a href="{{ path('home') }}"
                                class="pr-1 text-base font-medium text-body-color hover:text-primary">Accueil</a><span
                                class="mr-3 block h-2 w-2 rotate-45 border-t-2 border-r-2 border-body-color"></span>
                        </li>
                        <li class="text-base font-medium text-primary">Services</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="border-b border-body-color/[.15] pb-10 dark:border-white/[.15]"></div>
</section>

<section class="py-16 md:py-20 lg:py-28">
    <div class="container">
        {% if services is empty %}
        <p class="text-center text-body-color">Nos offres seront publiées prochainement.</p>
        {% else %}
        <div class="grid grid-cols-1 items-stretch gap-x-8 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
            {% for offre in services %}
            <div
                class="relative flex flex-col overflow-hidden rounded-xs p-8 shadow-two transition-transform duration-300 {{ offre.highlight ? 'bg-primary text-white shadow-lg ring-2 ring-primary/30' : 'bg-white hover:scale-[1.02] dark:bg-gray-dark' }}">
                {% if offre.highlight %}<span
                    class="absolute right-4 top-4 rounded-full bg-white/20 px-3 py-1 text-xs font-semibold text-white">Populaire</span>{%
                endif %}
                <h3 class="mb-2 text-xl font-bold {{ offre.highlight ? 'text-white' : 'text-black dark:text-white' }}">
                    {{ offre.title }}</h3>
                {% if offre.cible %}<p
                    class="mb-4 text-sm font-medium {{ offre.highlight ? 'text-white/80' : 'text-primary' }}">Pour : {{
                    offre.cible }}</p>{% endif %}
                <p
                    class="mb-6 text-sm leading-relaxed {{ offre.highlight ? 'text-white/90' : 'text-body-color dark:text-body-color-dark' }}">
                    {{ offre.description }}</p>
                {% if offre.livrables|length %}
                <ul class="mb-6 space-y-2">
                    {% for l in offre.livrables %}
                    <li class="flex items-center gap-2 text-sm">
                        {{ ux_icon('lucide:check', { class: 'shrink-0 h-4 w-4 ' ~ (offre.highlight ? 'text-white' : 'text-primary') }) }}
                        <span
                            class="{{ offre.highlight ? 'text-white/90' : 'text-body-color dark:text-body-color-dark' }}">{{
                            l }}</span>
                    </li>
                    {% endfor %}
                </ul>
                {% endif %}
                {% if offre.delai %}<div
                    class="mb-6 text-xs font-medium {{ offre.highlight ? 'text-white/70' : 'text-body-color' }}">Délai
                    indicatif : {{ offre.delai }}</div>{% endif %}
                <a href="{{ path('contact') }}"
                    class="mt-auto block w-full rounded-xs py-3 text-center text-sm font-semibold transition {{ offre.highlight ? 'bg-white text-primary hover:bg-white/90' : 'bg-primary text-white hover:bg-primary/90' }}">Demander
                    un devis</a>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</section>
{% endblock %}