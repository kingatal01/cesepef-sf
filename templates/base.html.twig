<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ title|default("CESEPEF, Cabinet d'Expertise Tchad") }}{% endblock %}</title>
    <meta name="description"
        content="{% block meta_description %}Cabinet d'Expertise de Suivi & Évaluation de Projets, d'Études et de Formations. N'Djamena, Tchad.{% endblock %}">
    {#
    <link rel="icon" href="{{ asset('images/favicon.png') }}"> #}

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    {# Police Inter — chargée via
    <link> (et non @import CSS, que css-loader corromprait) #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap">

    {# Anti-flash : applique le thème avant le rendu #}
    <script>
        (function () {
            try {
                if (localStorage.getItem('theme') === 'dark') {
                    document.documentElement.classList.add('dark');
                }
            } catch (e) { }
        })();
    </script>

    {% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>

<body class="bg-[#FCFCFC] dark:bg-black">
    <div class="isolate">
        {# ════════════ HEADER ════════════ #}
        {% set current = app.request.attributes.get('_route') %}
        {% set menu = [
        { title: 'Accueil', route: 'home' },
        { title: 'À propos', route: 'about' },
        { title: 'Expertises', route: 'expertises' },
        { title: 'Services', route: 'services' },
        { title: 'Réalisations', route: 'realisations' },
        { title: 'Blog', route: 'blog' }
        ] %}
        <header data-controller="navbar" data-navbar-target="header"
            class="header top-0 left-0 z-40 flex w-full items-center absolute bg-transparent">
            <div class="container">
                <div class="relative -mx-4 flex items-center justify-between">
                    <div class="w-60 max-w-full px-4 xl:mr-12">
                        <a href="{{ path('home') }}" data-navbar-target="logo" class="header-logo block w-full py-8">
                            <img src="{{ asset('images/logo/logo-cesepef.jpg') }}" alt="CESEPEF" width="160" height="60"
                                class="h-auto max-h-[50px] w-auto">
                        </a>
                    </div>
                    <div class="flex w-full items-center justify-between px-4">
                        <div>
                            <button data-action="navbar#toggle" aria-label="Menu mobile"
                                class="ring-primary absolute top-1/2 right-4 block translate-y-[-50%] rounded-lg px-3 py-[6px] focus:ring-2 lg:hidden">
                                <span data-navbar-target="bar1"
                                    class="relative my-1.5 block h-0.5 w-[30px] bg-black transition-all duration-300 dark:bg-white"></span>
                                <span data-navbar-target="bar2"
                                    class="relative my-1.5 block h-0.5 w-[30px] bg-black transition-all duration-300 dark:bg-white"></span>
                                <span data-navbar-target="bar3"
                                    class="relative my-1.5 block h-0.5 w-[30px] bg-black transition-all duration-300 dark:bg-white"></span>
                            </button>
                            <nav data-navbar-target="menu"
                                class="navbar border-body-color/50 dark:border-body-color/20 dark:bg-dark absolute right-0 z-30 w-[250px] rounded border-[.5px] bg-white px-6 py-4 duration-300 lg:visible lg:static lg:w-auto lg:border-none lg:!bg-transparent lg:p-0 lg:opacity-100 invisible top-[120%] opacity-0">
                                <ul class="block lg:flex lg:space-x-12">
                                    {% for item in menu %}
                                    <li class="group relative">
                                        <a href="{{ path(item.route) }}"
                                            class="flex py-2 text-base lg:mr-0 lg:inline-flex lg:px-0 lg:py-6 {{ current == item.route ? 'text-primary dark:text-white' : 'text-dark hover:text-primary dark:text-white/70 dark:hover:text-white' }}">{{
                                            item.title }}</a>
                                    </li>
                                    {% endfor %}
                                </ul>
                            </nav>
                        </div>
                        <div class="flex items-center justify-end pr-16 lg:pr-0">
                            <a href="{{ path('contact') }}"
                                class="ease-in-up shadow-btn hover:shadow-btn-hover bg-primary hover:bg-primary/90 hidden rounded-xs px-8 py-3 text-base font-medium text-white transition duration-300 md:block md:px-9 lg:px-6 xl:px-9">Contact</a>
                            <button data-controller="theme-toggle" data-action="theme-toggle#toggle"
                                aria-label="Basculer le thème"
                                class="flex items-center justify-center text-black rounded-full cursor-pointer bg-gray-2 dark:bg-dark-bg h-9 w-9 dark:text-white md:h-14 md:w-14">
                                {{ ux_icon('lucide:moon', { class: 'w-5 h-5 dark:hidden md:h-6 md:w-6' }) }}
                                {{ ux_icon('lucide:sun', { class: 'hidden w-5 h-5 dark:block md:h-6 md:w-6' }) }}
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        {% block body %}{% endblock %}

        {# ════════════ FOOTER ════════════ #}
        <footer class="relative z-10 bg-white pt-16 dark:bg-gray-dark md:pt-20 lg:pt-24">
            <div class="container">
                <div class="-mx-4 flex flex-wrap">
                    <div class="w-full px-4 md:w-1/2 lg:w-4/12 xl:w-5/12">
                        <div class="mb-12 max-w-[360px] lg:mb-16">
                            <a href="{{ path('home') }}" class="mb-8 inline-block">
                                <img src="{{ asset('images/logo/logo-cesepef.jpg') }}" alt="CESEPEF" width="160"
                                    height="60" class="h-auto max-h-[50px] w-auto">
                            </a>
                            <p class="mb-4 text-base leading-relaxed text-body-color dark:text-body-color-dark">Cabinet
                                d'Expertise de Suivi &amp; Évaluation de Projets, d'Études et de Formations.</p>
                            <p class="mb-9 text-sm text-body-color dark:text-body-color-dark">N'Djamena, Tchad | Fondé
                                en octobre 2021<br>NIF : 9031479 | SARL pluripersonnelle</p>
                            <div class="flex items-center gap-4">
                                <a href="https://linkedin.com" aria-label="LinkedIn" target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">
                                    {{ ux_icon('bi:linkedin', { class: 'h-[18px] w-[18px]' }) }}
                                </a>
                                <a href="mailto:info@cesepef.org" aria-label="Email"
                                    class="text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">
                                    {{ ux_icon('bi:envelope-fill', { class: 'h-[18px] w-[18px]' }) }}
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="w-full px-4 sm:w-1/2 md:w-1/2 lg:w-2/12 xl:w-2/12">
                        <div class="mb-12 lg:mb-16">
                            <h2 class="mb-10 text-xl font-bold text-black dark:text-white">Navigation</h2>
                            <ul>
                                {% for l in [
                                { label: 'Accueil', route: 'home' }, { label: 'À propos', route: 'about' },
                                { label: 'Expertises', route: 'expertises' }, { label: 'Services', route: 'services' },
                                { label: 'Réalisations', route: 'realisations' }
                                ] %}
                                <li><a href="{{ path(l.route) }}"
                                        class="mb-4 inline-block text-base text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">{{
                                        l.label }}</a></li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                    <div class="w-full px-4 sm:w-1/2 md:w-1/2 lg:w-2/12 xl:w-2/12">
                        <div class="mb-12 lg:mb-16">
                            <h2 class="mb-10 text-xl font-bold text-black dark:text-white">Ressources</h2>
                            <ul>
                                <li><a href="{{ path('blog') }}"
                                        class="mb-4 inline-block text-base text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">Publications</a>
                                </li>
                                <li><a href="{{ path('contact') }}"
                                        class="mb-4 inline-block text-base text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">Contact</a>
                                </li>
                                <li><a href="{{ path('home') }}"
                                        class="mb-4 inline-block text-base text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">Politique
                                        de confidentialité</a></li>
                                <li><a href="{{ path('home') }}"
                                        class="mb-4 inline-block text-base text-body-color duration-300 hover:text-primary dark:text-body-color-dark dark:hover:text-primary">Mentions
                                        légales</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="w-full px-4 md:w-1/2 lg:w-4/12 xl:w-3/12">
                        <div class="mb-12 lg:mb-16">
                            <h2 class="mb-10 text-xl font-bold text-black dark:text-white">Contact rapide</h2>
                            <p class="mb-3 text-sm text-body-color dark:text-body-color-dark"><span
                                    class="font-semibold text-black dark:text-white">Email :</span> <a
                                    href="mailto:info@cesepef.org" class="hover:text-primary">info@cesepef.org</a></p>
                            {# <p class="mb-3 text-sm text-body-color dark:text-body-color-dark">
                                <span class="font-semibold text-black dark:text-white">Propositions :</span>
                                <a href="mailto:propositions@cesepef.org"
                                    class="hover:text-primary">propositions@cesepef.org</a>
                            </p> #}
                            <p class="mb-3 text-sm text-body-color dark:text-body-color-dark"><span
                                    class="font-semibold text-black dark:text-white">Tél :</span> (+235) 66 38 64 14</p>
                            <p class="text-sm text-body-color dark:text-body-color-dark"><span
                                    class="font-semibold text-black dark:text-white">WhatsApp :</span> +235 66 38 64 14
                            </p>
                        </div>
                    </div>
                </div>
                <div
                    class="h-px w-full bg-linear-to-r from-transparent via-[#D2D8E183] to-transparent dark:via-[#959CB183]">
                </div>
                <div class="py-8">
                    <p class="text-center text-base text-body-color dark:text-white">© {{ "now"|date("Y") }} CESEPEF —
                        Cabinet d'Expertise de Suivi &amp; Évaluation de Projets, d'Études et de Formations. Tous droits
                        réservés.</p>
                </div>
            </div>
            <div class="absolute right-0 top-14 z-[-1]">
                <svg width="55" height="99" viewBox="0 0 55 99" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle opacity="0.8" cx="49.5" cy="49.5" r="49.5" fill="#959CB1" />
                </svg>
            </div>
        </footer>

        {# Retour en haut #}
        <div class="fixed right-8 bottom-8 z-99" data-controller="scroll-top">
            <button data-scroll-top-target="button" data-action="scroll-top#top" aria-label="Retour en haut"
                class="hidden bg-primary/80 flex h-10 w-10 cursor-pointer items-center justify-center rounded-md text-white shadow-md transition duration-300 ease-in-out hover:bg-primary">
                <span class="mt-[6px] h-3 w-3 rotate-45 border-t border-l border-white"></span>
            </button>
        </div>
    </div>
</body>

</html>