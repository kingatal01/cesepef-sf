{% extends 'base.html.twig' %}
{% set title = "Blog — CESEPEF" %}

{% block body %}
    <section class="relative z-10 overflow-hidden pt-28 lg:pt-[150px]">
        <div class="container">
            <div class="-mx-4 flex flex-wrap items-center">
                <div class="w-full px-4 md:w-8/12 lg:w-7/12">
                    <div class="mb-8 max-w-[570px] md:mb-0 lg:mb-12">
                        <h1 class="mb-5 text-2xl font-bold text-black dark:text-white sm:text-3xl">Publications &amp; Insights</h1>
                        <p class="text-base font-medium leading-relaxed text-body-color">Notes méthodologiques, analyses sectorielles et ressources pratiques pour les professionnels du suivi-évaluation et du développement.</p>
                    </div>
                </div>
                <div class="w-full px-4 md:w-4/12 lg:w-5/12">
                    <div class="text-end">
                        <ul class="flex items-center md:justify-end">
                            <li class="flex items-center"><a href="{{ path('home') }}" class="pr-1 text-base font-medium text-body-color hover:text-primary">Accueil</a><span class="mr-3 block h-2 w-2 rotate-45 border-t-2 border-r-2 border-body-color"></span></li>
                            <li class="text-base font-medium text-primary">Blog</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="border-b border-body-color/[.15] pb-10 dark:border-white/[.15]"></div>
    </section>

    <section class="py-16 md:py-20 lg:py-28">
        <div class="container">
            {% if articles is empty %}
                <p class="text-center text-body-color">Nos publications seront mises en ligne prochainement.</p>
            {% else %}
                <div class="grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-2 xl:grid-cols-3">
                    {% for article in articles %}
                        {% set tag = article.tags ? article.tags|first : article.category %}
                        <div class="group relative overflow-hidden rounded-xs bg-white shadow-one duration-300 hover:shadow-two dark:bg-dark">
                            <a href="{{ path('blog_detail', {slug: article.slug}) }}" class="relative block aspect-[37/22] w-full overflow-hidden">
                                {% if tag %}<span class="absolute right-6 top-6 z-20 inline-flex items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-semibold capitalize text-white">{{ tag }}</span>{% endif %}
                                {% if article.coverImage %}<img src="{{ article.coverImage }}" alt="{{ article.title }}" class="h-full w-full object-cover transition duration-300 group-hover:scale-105">
                                {% else %}<div class="flex h-full w-full items-center justify-center bg-primary/10"><span class="text-4xl font-bold text-primary/20">{{ article.title|first }}</span></div>{% endif %}
                            </a>
                            <div class="p-6 sm:p-8">
                                <h3><a href="{{ path('blog_detail', {slug: article.slug}) }}" class="mb-4 block text-xl font-bold text-black hover:text-primary dark:text-white dark:hover:text-primary sm:text-2xl">{{ article.title }}</a></h3>
                                <p class="mb-6 border-b border-body-color/10 pb-6 text-base font-medium text-body-color dark:border-white/10">{{ article.excerpt ?: article.content|slice(0, 120) ~ '…' }}</p>
                                <div class="flex items-center justify-between">
                                    <span class="text-sm font-medium text-body-color dark:text-body-color-dark">{{ article.author }}</span>
                                    <span class="text-xs text-body-color dark:text-body-color-dark">{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
