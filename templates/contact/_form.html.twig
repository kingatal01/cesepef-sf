{# Formulaire de contact + coordonnées (soumission AJAX branchée en Phase 4) #}
{% set inputCls = 'border-stroke w-full rounded-xs border bg-[#f8f8f8] px-6 py-3 text-base text-body-color outline-hidden focus:border-primary dark:border-transparent dark:bg-[#2C303B] dark:text-body-color-dark dark:shadow-two dark:focus:border-primary dark:focus:shadow-none' %}
<section id="contact" class="overflow-hidden py-16 md:py-20 lg:py-28">
    <div class="container">
        <div class="-mx-4 flex flex-wrap">
            <div class="w-full px-4 lg:w-7/12 xl:w-8/12">
                <div class="mb-12 rounded-xs bg-white px-8 py-11 shadow-three dark:bg-gray-dark sm:p-[55px] lg:mb-5 lg:px-8 xl:p-[55px]">
                    <h2 class="mb-3 text-2xl font-bold text-black dark:text-white sm:text-3xl lg:text-2xl xl:text-3xl">Vous portez un projet ou un appel d'offres ?</h2>
                    <p class="mb-12 text-base font-medium text-body-color">Notre équipe étudie attentivement chaque sollicitation et revient vers vous sous 48 heures ouvrées avec une première proposition de cadrage.</p>

                    {% for m in app.flashes('contact_success') %}
                        <div class="mb-8 rounded-xs bg-green-50 px-6 py-4 text-sm text-green-700 dark:bg-green-950 dark:text-green-300">{{ m }}</div>
                    {% endfor %}
                    {% for m in app.flashes('contact_error') %}
                        <div class="mb-8 rounded-xs bg-red-50 px-6 py-4 text-sm text-red-600 dark:bg-red-950 dark:text-red-400">{{ m }}</div>
                    {% endfor %}

                    <form method="post" action="{{ path('contact_submit') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">
                        <div class="-mx-4 flex flex-wrap">
                            <div class="w-full px-4 md:w-1/2">
                                <div class="mb-8">
                                    <label for="name" class="mb-3 block text-sm font-medium text-dark dark:text-white">Nom & prénom *</label>
                                    <input required id="name" name="name" type="text" placeholder="Votre nom complet" class="{{ inputCls }}">
                                </div>
                            </div>
                            <div class="w-full px-4 md:w-1/2">
                                <div class="mb-8">
                                    <label for="email" class="mb-3 block text-sm font-medium text-dark dark:text-white">Email professionnel *</label>
                                    <input required id="email" name="email" type="email" placeholder="votre@email.org" class="{{ inputCls }}">
                                </div>
                            </div>
                            <div class="w-full px-4 md:w-1/2">
                                <div class="mb-8">
                                    <label for="phone" class="mb-3 block text-sm font-medium text-dark dark:text-white">Téléphone</label>
                                    <input id="phone" name="phone" type="tel" placeholder="+235 XX XX XX XX" class="{{ inputCls }}">
                                </div>
                            </div>
                            <div class="w-full px-4 md:w-1/2">
                                <div class="mb-8">
                                    <label for="subject" class="mb-3 block text-sm font-medium text-dark dark:text-white">Type de demande *</label>
                                    <select required id="subject" name="subject" class="{{ inputCls }}">
                                        <option value="">Sélectionner...</option>
                                        <option>Demande d'information</option>
                                        <option>Demande de proposition technique et financière</option>
                                        <option>Partenariat</option>
                                        <option>Recrutement / Expert associé</option>
                                        <option>Presse</option>
                                        <option>Autre</option>
                                    </select>
                                </div>
                            </div>
                            <div class="w-full px-4">
                                <div class="mb-8">
                                    <label for="service" class="mb-3 block text-sm font-medium text-dark dark:text-white">Service concerné</label>
                                    <select id="service" name="service" class="{{ inputCls }}">
                                        <option value="">— Optionnel —</option>
                                        <option>Évaluation 360°</option>
                                        <option>Système SERA clé en main</option>
                                        <option>Étude de référence (Baseline)</option>
                                        <option>Étude sectorielle ou de filière</option>
                                        <option>Formations certifiantes & sur mesure</option>
                                        <option>Assistance technique aux appels à projets</option>
                                        <option>Diagnostic territorial & développement local</option>
                                    </select>
                                </div>
                            </div>
                            <div class="w-full px-4">
                                <div class="mb-8">
                                    <label for="message" class="mb-3 block text-sm font-medium text-dark dark:text-white">Votre message *</label>
                                    <textarea required id="message" name="message" rows="5" placeholder="Décrivez votre besoin, votre projet ou votre question..." class="{{ inputCls }} resize-none"></textarea>
                                </div>
                            </div>
                            <div class="w-full px-4">
                                <div class="mb-8 flex items-start gap-3">
                                    <input type="checkbox" id="rgpd" name="rgpd" value="1" required class="mt-1">
                                    <label for="rgpd" class="text-sm text-body-color dark:text-body-color-dark">J'accepte que mes données soient utilisées uniquement pour traiter ma demande, conformément à la politique de confidentialité de CESEPEF.</label>
                                </div>
                            </div>
                            <div class="w-full px-4">
                                <button type="submit" class="flex items-center gap-3 rounded-xs bg-primary px-9 py-4 text-base font-medium text-white shadow-submit duration-300 hover:bg-primary/90 dark:shadow-submit-dark">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                                    Envoyer ma demande
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="w-full px-4 lg:w-5/12 xl:w-4/12">
                <div class="rounded-xs bg-white p-8 shadow-three dark:bg-gray-dark">
                    <h3 class="mb-6 text-xl font-bold text-black dark:text-white">Coordonnées institutionnelles</h3>
                    <div class="mb-5 flex items-start gap-3">
                        <span class="mt-1 text-primary"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></span>
                        <div>
                            <p class="font-semibold text-black dark:text-white">Siège</p>
                            <p class="text-sm text-body-color dark:text-body-color-dark">7ᵉ Arrondissement, Quartier Abéna<br>Axe Hôtel Mirande, N'Djamena – Tchad<br>BP 716, N'Djamena</p>
                        </div>
                    </div>
                    <div class="mb-5 flex items-start gap-3">
                        <span class="mt-1 text-primary"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></span>
                        <div>
                            <p class="font-semibold text-black dark:text-white">Téléphones</p>
                            <p class="text-sm text-body-color dark:text-body-color-dark">(+235) 66 38 64 14<br>(+235) 68 82 62 43<br>(+235) 66 23 66 89</p>
                            <p class="mt-1 text-xs text-primary">WhatsApp (urgences) : +235 66 38 64 14</p>
                        </div>
                    </div>
                    <div class="mb-5 flex items-start gap-3">
                        <span class="mt-1 text-primary"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></span>
                        <div>
                            <p class="font-semibold text-black dark:text-white">Emails</p>
                            <a href="mailto:info@cesepef.org" class="block text-sm text-primary hover:underline">info@cesepef.org</a>
                            <a href="mailto:propositions@cesepef.org" class="block text-sm text-primary hover:underline">propositions@cesepef.org</a>
                            <a href="mailto:rh@cesepef.org" class="block text-sm text-primary hover:underline">rh@cesepef.org</a>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <span class="mt-1 text-primary"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg></span>
                        <div>
                            <p class="font-semibold text-black dark:text-white">Horaires</p>
                            <p class="text-sm text-body-color dark:text-body-color-dark">Lun – Jeu : 8h00 – 17h00 (GMT+1)<br>Vendredi : 8h00 – 13h00<br>Samedi : sur rendez-vous</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
