{# Localisation — carte Google Maps + adresse #}
<section class="py-16 md:py-20 lg:py-28">
    <div class="container">
        <div class="-mx-4 flex flex-wrap items-center">
            <div class="w-full px-4 lg:w-1/2">
                <div class="mb-12 lg:mb-0">
                    <h2 class="mb-4 text-3xl font-bold text-black dark:text-white sm:text-4xl">Où nous trouver</h2>
                    <p class="mb-6 text-base text-body-color dark:text-body-color-dark">Nos bureaux sont situés au cœur de N'Djamena, dans le 7ᵉ Arrondissement, Quartier Abéna, sur l'axe Hôtel Mirande (à 600 m après l'hôtel Mirande).</p>
                    <ul class="space-y-3 text-sm text-body-color dark:text-body-color-dark">
                        <li class="flex items-start gap-3">
                            <span class="mt-0.5 text-primary">{{ ux_icon('lucide:map-pin', { class: 'h-[18px] w-[18px]' }) }}</span>
                            <span>7ᵉ Arrondissement, Quartier Abéna, axe Hôtel Mirande N'Djamena, Tchad</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="mt-0.5 text-primary">{{ ux_icon('bi:envelope-fill', { class: 'h-[18px] w-[18px]' }) }}</span>
                            <span>BP 716, N'Djamena – Tchad</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="mt-0.5 text-primary">{{ ux_icon('lucide:phone', { class: 'h-[18px] w-[18px]' }) }}</span>
                            <span>(+235) 66 38 64 14 / 68 82 62 43</span>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="w-full px-4 lg:w-1/2">
                <div class="overflow-hidden rounded-xs shadow-two">
                    <iframe src="https://maps.google.com/maps?q=12.0968984,15.1206857&z=17&output=embed&hl=fr" width="100%" height="400" style="border:0" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Localisation CESEPEF — N'Djamena"></iframe>
                </div>
                <div class="mt-4 text-right">
                    <a href="https://www.google.com/maps/dir/?api=1&destination=12.0968984,15.1206857" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xs bg-primary px-6 py-3 text-sm font-semibold text-white transition hover:bg-primary/90">
                        {{ ux_icon('lucide:navigation', { class: 'h-4 w-4' }) }}
                        Naviguer vers CESEPEF
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
